generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ORGANIZER
  PARTICIPANT
  GUEST
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id          Int        @id @default(autoincrement())
  username    String     @unique
  password    String
  firstName   String
  lastName    String
  email       String     @unique
  phone       String
  address     String
  city        String
  country     String
  geoLat      Float?
  geoLng      Float?
  vatNumber   String
  role        Role       @default(PARTICIPANT)
  status      UserStatus @default(PENDING)
  createdAt   DateTime   @default(now())

  organizedEvents  Event[]    @relation("OrganizerEvents")
  bookings         Booking[]
  sentMessages     Message[]  @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  eventViews    EventView[]
}

model Event {
  id            Int         @id @default(autoincrement())
  eventId       String      @unique
  title         String
  eventType     String
  venue         String
  address       String
  city          String
  country       String
  geoLat        Float?
  geoLng        Float?
  startDateTime DateTime
  endDateTime   DateTime
  capacity      Int
  status        EventStatus @default(DRAFT)
  description   String
  createdAt     DateTime    @default(now())

  organizerId   Int
  organizer     User        @relation("OrganizerEvents", fields: [organizerId], references: [id])

  categories    EventCategory[]
  ticketTypes   TicketType[]
  bookings      Booking[]
  photos        EventPhoto[]
  views         EventView[]
}

model Category {
  id     Int             @id @default(autoincrement())
  name   String          @unique
  events EventCategory[]
}

model EventCategory {
  eventId    Int
  categoryId Int
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([eventId, categoryId])
}

model TicketType {
  id        Int    @id @default(autoincrement())
  ticketId  String
  name      String
  price     Float
  quantity  Int
  available Int

  eventId   Int
  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  bookings  Booking[]
}

model Booking {
  id              Int           @id @default(autoincrement())
  bookingId       String        @unique
  numberOfTickets Int
  totalCost       Float
  status          BookingStatus @default(CONFIRMED)
  time            DateTime      @default(now())

  attendeeId    Int
  attendee      User       @relation(fields: [attendeeId], references: [id])

  eventId       Int
  event         Event      @relation(fields: [eventId], references: [id])

  ticketTypeId  Int
  ticketType    TicketType @relation(fields: [ticketTypeId], references: [id])
}

model Message {
  id                  Int      @id @default(autoincrement())
  subject             String
  body                String
  isReadByReceiver    Boolean  @default(false)
  deletedBySender     Boolean  @default(false)
  deletedByReceiver   Boolean  @default(false)
  createdAt           DateTime @default(now())

  senderId    Int
  sender      User @relation("SentMessages", fields: [senderId], references: [id])

  receiverId  Int
  receiver    User @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model EventPhoto {
  id       Int    @id @default(autoincrement())
  filename String

  eventId  Int
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventView {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventId   Int
  viewedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}